<% layout('layout/boilerplate') %>
   <link rel="stylesheet" href="/stylesheets/stars.css">

   <div class="row">

      <div class="col-6 ">
         <div class="card mb-3">
            <div class="card-body ">
               <div class="row">
                  <div class="col">
                     <h1>
                        <%= vetplace.name %>
                     </h1>
                     <p class="text-muted">Location: <%= vetplace.location %>
                     </p>
                     <div id="carouselVet" class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-inner">
                           <% vetplace.images.forEach((img,i)=>{ %>
                              <div class="carousel-item <%= i===0?'active':'' %>">
                                 <img src=" <%=img.url %>" class="d-block w-100" alt="...">
                              </div>
                              <% }) %>
                        </div>
                        <% if(vetplace.images.length>1){ %>
                           <button class="carousel-control-prev" type="button" data-bs-target="#carouselVet"
                              data-bs-slide="prev">
                              <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                              <span class="visually-hidden">Previous</span>
                           </button>
                           <button class="carousel-control-next" type="button" data-bs-target="#carouselVet"
                              data-bs-slide="next">
                              <span class="carousel-control-next-icon" aria-hidden="true"></span>
                              <span class="visually-hidden">Next</span>
                           </button>
                           <% } %>
                     </div>
                  </div>
               </div>
               <div class="row mt-3">
                  <div class="col">
                     <b>
                        <p class="text">
                           Submitted by : <%= vetplace.author.username %>
                        </p>
                     </b>
                  </div>
               </div>
               <div class="row mt-1">
                  <div class="col">
                     <p class="text">
                        Consultation price : <%= vetplace.consultationPrice %> RON
                     </p>
                  </div>
               </div>
               <div class="row mt-1">
                  <p class="text">
                     Specialization : <%= String(vetplace.specialization).charAt(0).toUpperCase() +
                        String(vetplace.specialization).slice(1) %>
                  </p>
               </div>
               <% if(currentUser && vetplace.author.equals(currentUser._id)){ %>
                  <div class="row mt-3 mb-3">
                     <div class="col d-flex gap-2">
                        <a class="btn btn-success" href="/vetplaces/<%=vetplace.id%>/edit">Edit</a>
                        <form action="/vetplaces/<%=vetplace.id%>?_method=DELETE" method="post">
                           <button class="btn btn-danger">Delete</button>
                        </form>
                     </div>
                  </div>
                  <% } %>
                     <% if(currentUser){ %>
                        <hr>
                        <h2>Leave a review</h2>
                        <form action="/vetplaces/<%=vetplace._id%>/reviews" method="post" novalidate
                           class="validated-form">
                           <div>
                              <label for="rating" class="form-label">Rating</label>
                              <fieldset class="starability-heart">
                                 <input type="radio" id="no-rate" class="input-no-rate" name="reviews[rating]" value="0"
                                    checked aria-label="No rating." />
                                 <input type="radio" id="first-rate1" name="reviews[rating]" value="1" />
                                 <label for="first-rate1" title="Terrible">1 star</label>
                                 <input type="radio" id="first-rate2" name="reviews[rating]" value="2" />
                                 <label for="first-rate2" title="Not good">2 stars</label>
                                 <input type="radio" id="first-rate3" name="reviews[rating]" value="3" />
                                 <label for="first-rate3" title="Average">3 stars</label>
                                 <input type="radio" id="first-rate4" name="reviews[rating]" value="4" />
                                 <label for="first-rate4" title="Very good">4 stars</label>
                                 <input type="radio" id="first-rate5" name="reviews[rating]" value="5" />
                                 <label for="first-rate5" title="Amazing">5 stars</label>
                              </fieldset>
                           </div>
                           <div class="mb-3">
                              <label for="body" class="form-label">Review Comment: </label>
                              <textarea class="form-control" name="reviews[body]" value="reviews[body]" id="body"
                                 cols="30" rows="3" required></textarea>
                           </div>
                           <div class="mb-3">
                              <button class="btn btn-secondary">Submit</button>
                           </div>
                        </form>
                        <% } %>
            </div>
         </div>
      </div>

      <div class="col-6">
         <h2 class="mt-3">Reviews ⭐</h2>
         <hr>
         <%if(vetplace.reviews.length){%>
            <% for(let r of vetplace.reviews){ %>
               <div class="card mb-3">
                  <div class="card-header">
                     <%= r.author.username %>
                  </div>
                  <div class="card-body">
                     <p class="starability-result" data-rating=<%=r.rating %>>
                        Rated: 3 stars
                     </p>
                     <p class="card-text">
                        <%= r.body %>
                     </p>
                     <% if(currentUser && r.author.equals(currentUser._id)){ %>
                        <form action="/vetplaces/<%=vetplace._id%>/reviews/<%= r._id %>?_method=DELETE" method="post">
                           <button class="btn-sm btn btn-danger">Delete</button>
                        </form>
                        <% } %>
                  </div>
               </div>
               <% } %>
                  <% }else{ %>
                     <div class="row">
                        <!-- <img src="/missingReview.gif" alt="missingReviewGif" width="100" height="400"> -->
                        <p>No reviews yet !</p>
                     </div>

                     <% } %>
      </div>

      <div class="col mb-4">
         <div id="map" style="width: 100%;height: 400px;"></div>
      </div>

   </div>
<br>
   <script>
      const mapToken = '<%=process.env.MAPBOX_TOKEN %>';
      const vetplace = <%- JSON.stringify(vetplace) %>;
      // console.log(vetplace.geometry.coordinates)
   </script>
   <script src="/javascripts/showMap.js">
   </script>